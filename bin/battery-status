#!/usr/bin/env bash
# battery status with dynamic icons, conditional colours

CAPACITY=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null)
STATUS=$(cat /sys/class/power_supply/BAT0/status 2>/dev/null)

# catppuccin mocha colours (matching waybar battery states)
source "${HOME}/.config/themes/catppuccin.sh"
COLOR_NORMAL="${CATPPUCCIN_GREEN}"
COLOR_WARNING="${CATPPUCCIN_YELLOW}"
COLOR_CRITICAL="${CATPPUCCIN_RED}"

if [[ -z "${CAPACITY}" ]]; then
  echo "<span foreground=\"${COLOR_NORMAL}\">َ°‚‘ N/A</span>"
  exit 0
fi

# icons matching waybar config (5 levels, 0-4 index)
DISCHARGE_ICONS=(َ°پ؛ َ°پ¼ َ°پ¾ َ°‚پ َ°پ¹)
CHARGING_ICONS=(َ°¢œ َ°‚‡ َ°¢‌ َ°‚ٹ َ°‚…)

# icon index (0-4 based on capacity)
INDEX=$(((CAPACITY - 1) / 20))
[[ "${INDEX}" -lt 0 ]] && INDEX=0
[[ "${INDEX}" -gt 4 ]] && INDEX=4

case "${STATUS}" in
  Full)
    ICON="َ°‚…"
    ;;
  Charging|"Not charging")
    ICON="${CHARGING_ICONS[${INDEX}]}"
    ;;
  *)
    ICON="${DISCHARGE_ICONS[${INDEX}]}"
    ;;
esac

# colour based on capacity (matches waybar states)
if [[ "${CAPACITY}" -le 10 ]]; then
  COLOR="${COLOR_CRITICAL}"
elif [[ "${CAPACITY}" -le 20 ]]; then
  COLOR="${COLOR_WARNING}"
else
  COLOR="${COLOR_NORMAL}"
fi

echo "<span foreground=\"${COLOR}\">${ICON} ${CAPACITY}%</span>"
